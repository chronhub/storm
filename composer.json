 
{
    "name": "chronhub/storm",
    "description": "framework",
    "keywords": ["framework"],
    "license": "MIT",
    "authors": [
        {
            "name": "steph bug",
            "email": "chronhubgit@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "chronhub/aggregate": "dev-main"
    },
    "require-dev": {
        "laravel/framework": "9.x"
    },
    "autoload": {
        "psr-4": {
            "Storm\\": "src"
        }
    },
    "autoload-dev": {},
    "provide": {
        "chronhub/aggregate": "self.version"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "dev"
}
